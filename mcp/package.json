{
  "name": "@qe-craft/mcp",
  "version": "1.0.0",
  "description": "QE Craft MCP — guided qe_intel_* runs for copilot coaching; optional validate/save — no API key",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "qe-craft-mcp": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "npm run typecheck && npm run lint",
    "test": "npm run build && node --test dist/core/prompts/build-system-prompt.test.js dist/core/parse-report.test.js dist/core/validate-report.test.js dist/json-report-pipeline.test.js dist/report-renderer.test.js dist/file-writer.test.js dist/deterministic-tools.test.js dist/intel/intel-tools.test.js dist/init.test.js",
    "sync-skill": "cp \"$HOME/.cursor/skills/qe-analysis/SKILL.md\" skills/qe-analysis/SKILL.md",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm run test",
    "pack:check": "npm run build && npm pack --dry-run",
    "start": "node dist/server.js",
    "dev": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs src/server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arjunjh10/qe-craft.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/arjunjh10/qe-craft/issues"
  },
  "homepage": "https://github.com/arjunjh10/qe-craft#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "qe",
    "quality-engineering",
    "testing",
    "cursor",
    "uat",
    "test-plan",
    "qe-craft"
  ],
  "author": "Arjun Jhawar",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.28.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  }
}
